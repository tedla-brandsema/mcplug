{
  "server": {
    "name": "mcpfs",
    "version": "0.4.0",
    "transport": "stdio",
    "auth": {
      "mode": "none"
    }
  },
  "roots": [
    {
      "id": "mcpfs",
      "path": ".",
      "mode": "read_write",
      "include": ["**/*.go", "**/*.md", "**/*.json"],
      "exclude": ["**/.git/**", "**/.env", "**/.env.*", "**/*secret*", "**/*credential*", "**/*.pem", "**/*.key"],
      "use_gitignore": true,
      "max_file_bytes": 262144
    }
  ],
  "commands": {
    "mode": "disabled"
  }
}
