{
  "server": {
    "name": "mcpfs",
    "version": "0.4.0",
    "transport": "http_ngrok",
    "addr": "127.0.0.1:8080",
    "path": "/mcp",
    "auth": {
      "mode": "bearer",
      "token_env": "MCPFS_TOKEN"
    },
    "ngrok_url": ""
  },
  "roots": [
    {
      "id": "mcpfs",
      "path": ".",
      "mode": "read",
      "include": ["**/*.go", "**/*.md", "**/*.json", "**/*.mod", "**/*.sum"],
      "exclude": ["**/.git/**", "**/.env", "**/.env.*", "**/*secret*", "**/*credential*", "**/*.pem", "**/*.key"],
      "use_gitignore": true,
      "max_file_bytes": 262144
    }
  ],
  "commands": {
    "mode": "disabled"
  }
}
