{
  "server": {
    "name": "mcpfs",
    "version": "0.4.0",
    "transport": "http",
    "addr": "127.0.0.1:8080",
    "path": "/mcp",
    "auth": {
      "mode": "oidc",
      "issuer": "https://issuer.example.com",
      "audience": "mcpfs",
      "jwks_url": "https://issuer.example.com/.well-known/jwks.json",
      "allowed_subjects": ["user-or-client-subject-id"]
    }
  },
  "roots": [
    {
      "id": "mcpfs",
      "path": ".",
      "mode": "read",
      "include": ["**/*.go", "**/*.md", "**/*.json", "**/*.mod", "**/*.sum"],
      "exclude": ["**/.git/**", "**/.env", "**/.env.*", "**/*secret*", "**/*credential*", "**/*.pem", "**/*.key"],
      "use_gitignore": true,
      "max_file_bytes": 262144
    }
  ],
  "commands": {
    "mode": "disabled"
  }
}
