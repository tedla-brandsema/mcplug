{
  "server": {
    "name": "mcplug",
    "version": "2.0.0",
    "transport": "http",
    "addr": "127.0.0.1:8080",
    "path": "/mcp",
    "auth": {
      "mode": "bearer",
      "token_env": "MCPLUG_TOKEN"
    }
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/absolute/path/to/project"
      ],
      "includeTools": [
        "read_file",
        "read_text_file",
        "read_multiple_files",
        "list_directory",
        "directory_tree",
        "search_files",
        "get_file_info",
        "list_allowed_directories"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/absolute/path/to/project"
      ],
      "optional": true
    }
  }
}
