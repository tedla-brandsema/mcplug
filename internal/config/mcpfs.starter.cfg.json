{
  "server": {
    "name": "mcpfs",
    "version": "2.0.0",
    "transport": "stdio",
    "auth": {
      "mode": "none"
    }
  },
  "mcpServers": {
    "everything": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"],
      "disabled": true
    },
    "remote-example": {
      "url": "https://example.com/mcp",
      "headers": {
        "Authorization": "Bearer REPLACE_ME"
      },
      "disabled": true
    }
  }
}
